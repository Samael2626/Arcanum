# App Config
DEBUG=True
APP_NAME="Arcanum API"
APP_VERSION="0.1.0"

# Database
# Local development: postgresql://postgres:postgrespassword@localhost:5432/arcanum_db
# Production (Supabase): Use Supavisor to avoid IPv6 issues on Render
DATABASE_URL=postgresql://postgres:password@pooler.supabase.com:6543/postgres?user=postgres

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
